{
  "name": "@obsidian/data-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "wrangler deploy --dry-run",
    "deploy:prod": "wrangler deploy --env production",
    "db:generate": "node scripts/db-generate.mjs --env dev",
    "db:generate:dev": "node scripts/db-generate.mjs --env dev",
    "db:generate:prod": "node scripts/db-generate.mjs --env production",
    "db:migrate": "tsx src/db/migrate.ts --env dev",
    "db:migrate:dev": "tsx src/db/migrate.ts --env dev",
    "db:migrate:prod": "tsx src/db/migrate.ts --env production",
    "db:seed": "tsx src/db/seed.ts --env dev",
    "db:seed:dev": "tsx src/db/seed.ts --env dev",
    "db:seed:prod": "tsx src/db/seed.ts --env production",
    "collect:dev": "node scripts/collect-dev.mjs",
    "collect:check": "node scripts/check-collector.mjs",
    "discover:dev": "node scripts/discover-dev.mjs",
    "ingest:dev": "node scripts/ingest-dev.mjs"
  },
  "dependencies": {
    "agents": "^0.0.113",
    "drizzle-orm": "^0.44.0",
    "hono": "^4.7.0",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250320.0",
    "@types/node": "^20",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.19.0",
    "typescript": "^5",
    "wrangler": "^4.0.0"
  }
}
